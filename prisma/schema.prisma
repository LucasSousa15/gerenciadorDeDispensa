generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  GUEST
}

model Household {
  id   String @id @default(uuid())
  name String

  users      User[]
  pantry     PantryItem[]
  lists      ShoppingList[]
  categories Category[]

  createdAt DateTime @default(now())
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(GUEST)

  household   Household @relation(fields: [householdId], references: [id])
  householdId String

  createdLists ShoppingList[] @relation("CreatedLists")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   String @id @default(uuid())
  name String

  household   Household @relation(fields: [householdId], references: [id])
  householdId String

  pantryItems PantryItem[]

  createdAt DateTime @default(now())

  @@unique([name, householdId])
}

model PantryItem {
  id       String @id @default(uuid())
  name     String
  quantity Int

  household   Household @relation(fields: [householdId], references: [id])
  householdId String

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  listItems ShoppingListItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShoppingList {
  id       String  @id @default(uuid())
  title    String
  isActive Boolean @default(true)

  household   Household @relation(fields: [householdId], references: [id])
  householdId String

  createdBy   User   @relation("CreatedLists", fields: [createdById], references: [id])
  createdById String

  items ShoppingListItem[]

  createdAt DateTime @default(now())
}

model ShoppingListItem {
  id       String  @id @default(uuid())
  quantity Int
  price    Decimal @db.Decimal(10, 2)

  pantryItem   PantryItem @relation(fields: [pantryItemId], references: [id])
  pantryItemId String

  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id])
  shoppingListId String
}
